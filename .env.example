# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
# Model đã được kèm sẵn ở thư mục gốc repo; có thể để ./models/... nếu bạn di chuyển nó.
LOCAL_MODEL_PATH=./Phi-3-mini-4k-instruct-q4.gguf
# GPU offload (cần bản llama-cpp-python build CUDA/Metal/Vulkan mới có tác dụng):
#   0  = chỉ CPU (mặc định)
#   -1 = offload toàn bộ layer lên GPU (nhanh nhất, cần đủ VRAM)
#   N  = offload N layer, phần còn lại chạy CPU (dùng khi VRAM ít, vd card 4 GB)
LOCAL_GPU_LAYERS=0

# LAB CONFIG
# Options: openai | google | local   (mặc định local để chạy offline)
DEFAULT_PROVIDER=local
DEFAULT_MODEL=gpt-4o
LOG_LEVEL=INFO
